          id(${wake_word_flow_active_id}) = true;
          id(${display_awake_until_id}) = millis() + 300000UL;
          id(${voice_assistant_phase_global_id}) = ${voice_assist_waiting_for_command_phase_id};
          id(${va_ultimo_input_ms_id}) = millis();

      - if:
          condition:
            switch.is_on: ${wake_sound_switch_id}
          then:
            - script.execute:
                id: ${script_play_sound_id}
                priority: false
                sound_file: !lambda return id(${wake_word_triggered_sound_id});

            # Piccola attesa per lasciare partire e finire il ding.
            # Se il file è più lungo, aumenta a 500/600ms.
            - delay: 400ms

      - if:
          condition:
            lambda: return id(${va_modalita_continua_id});
          then:
            - voice_assistant.start_continuous:
          else:
            - voice_assistant.start:
                wake_word: !lambda return detected_wake_word;

      - delay: 200ms
      - lambda: |-
