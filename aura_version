script:

  # ======================================================
  # AURA - BARRA DI AVANZAMENTO BOOT
  # 18 step: Wi-Fi, Home Assistant e 16 immagini Aura.
  # Il riempimento avanza a scatti e passa da rosso a verde.
  # ======================================================
  - id: aura_refresh_boot_progress
    mode: restart
    then:
      - lambda: |-
          int step = 0;

          if (id(${wifi_component_id}).is_connected()) {
            step = 1;
          }

          if (id(${api_component_id}).is_connected()) {
            step = 2 + id(aura_download_step);
          }

          if (step < 0) step = 0;
          if (step > 18) step = 18;
          id(aura_boot_progress_step) = step;

      - lvgl.bar.update:
          id: aura_boot_progress_bar
          value: !lambda return id(aura_boot_progress_step);
          indicator:
            bg_color: !lambda |-
              if (id(aura_boot_progress_error)) {
                return lv_color_hex(0xFF3030);
              }

              const float t = id(aura_boot_progress_step) / 18.0f;
              int r = 255;
              int g = 0;
              const int b = 32;

              if (t <= 0.5f) {
                g = (int)(t * 2.0f * 220.0f);
              } else {
                r = (int)((1.0f - t) * 2.0f * 255.0f);
                g = 220;
              }

              if (r < 0) r = 0;
              if (r > 255) r = 255;
              if (g < 0) g = 0;
              if (g > 255) g = 255;

              const uint32_t rgb =
                ((uint32_t) r << 16) |
                ((uint32_t) g << 8)  |
                (uint32_t) b;

              return lv_color_hex(rgb);

      - lvgl.label.update:
          id: aura_boot_progress_label
          text: !lambda |-
            char buf[16];
            const int pct =
              (id(aura_boot_progress_step) * 100 + 9) / 18;
            snprintf(buf, sizeof(buf), "%d%%", pct);
            return std::string(buf);
          text_color: !lambda |-
            if (id(aura_boot_progress_error)) {
              return lv_color_hex(0xFCA5A5);
            }
            if (id(aura_boot_progress_step) >= 18) {
              return lv_color_hex(0x86EFAC);
            }
            return lv_color_hex(0xCBD5E1);

  # ======================================================
  # AURA - CONCLUDE IL BOOT SOLO QUANDO TUTTO E PRONTO
  # ======================================================
  - id: aura_try_finish_boot
    mode: restart
    then:
      - script.execute: aura_refresh_boot_progress

      # Testo dinamico durante le varie fasi di inizializzazione.
      - lvgl.label.update:
          id: aura_boot_status
          text: !lambda |-
            if (!id(${wifi_component_id}).is_connected()) {
              return std::string("Connessione Wi-Fi...");
            }
            if (!id(${api_component_id}).is_connected()) {
              return std::string("In attesa di Home Assistant...");
            }
            if (!id(aura_assets_ready)) {
              if (!id(aura_download_status).empty()) {
                return id(aura_download_status);
              }
              return std::string("Caricamento immagini Aura...");
            }
            return std::string("Aura pronta");

      - if:
          condition:
            lambda: |-
              if (id(aura_boot_finished)) return false;
              if (!id(${api_component_id}).is_connected()) return false;
              if (!id(aura_assets_ready)) return false;

              // Evita un passaggio troppo brusco nel caso di boot molto rapido.
              if (id(aura_boot_started_ms) == 0) return false;
              return (millis() - id(aura_boot_started_ms)) >= 1500UL;
          then:
            - lambda: |-
                id(aura_boot_finished) = true;
                id(aura_ui_ready) = true;
                id(aura_last_phase) = -999;
                id(aura_last_activity_ms) = millis();
                id(${display_awake_until_id}) = millis() + 300000UL;

            - lvgl.label.update:
                id: aura_boot_status
                text: "Aura pronta"
                text_color: 0x86EFAC

            - delay: 250ms

            - lvgl.image.update:
                id: aura_main_image
                src: aura_idle_standby_img

            - lvgl.page.show:
                id: aura_page
                animation: FADE_IN
                time: 500ms

            - script.execute: aura_apply_phase
            - script.execute: aura_refresh_runtime_ui

  # ======================================================
  # AURA - PAGINA PRINCIPALE
  # ======================================================
  - id: aura_blink
    mode: single
    then:
      - if:
          condition:
            lambda: |-
              if (!id(aura_assets_ready)) return false;
              if (id(aura_music_mode)) return false;
              if (id(aura_sleeping)) return false;
              if (id(aura_speaking)) return false;
              if (id(aura_animation_running)) return false;
              if (id(${voice_assistant_phase_global_id}) != ${voice_assist_idle_phase_id}) return false;
              if (id(${display_emotion_mode_id}) != 0) return false;
              return true;
          then:
            - lambda: |-
                id(aura_animation_running) = true;
                id(aura_blink_running) = true;

            - lvgl.image.update:
                id: aura_main_image
                src: aura_blink_half_closed_img
            - delay: 70ms

            - lvgl.image.update:
                id: aura_main_image
                src: aura_blink_closed_img
            - delay: 90ms

            - lvgl.image.update:
                id: aura_main_image
                src: aura_blink_half_closed_img
            - delay: 70ms

            - lvgl.image.update:
                id: aura_main_image
                src: aura_idle_standby_img

            - if:
                condition:
                  lambda: return (esp_random() % 100) < 20;
                then:
                  - delay: 120ms
                  - lvgl.image.update:
                      id: aura_main_image
                      src: aura_blink_half_closed_img
                  - delay: 60ms
                  - lvgl.image.update:
                      id: aura_main_image
                      src: aura_blink_closed_img
                  - delay: 80ms
                  - lvgl.image.update:
                      id: aura_main_image
                      src: aura_blink_half_closed_img
                  - delay: 60ms
                  - lvgl.image.update:
                      id: aura_main_image
                      src: aura_idle_standby_img

            - lambda: |-
                id(aura_blink_running) = false;
                id(aura_animation_running) = false;
                id(aura_next_blink_ms) =
                  millis() + 6000UL + (esp_random() % 14001UL);

  # ======================================================
  # AURA - ESPRESSIONI IDLE CASUALI
  # ======================================================
  - id: aura_random_idle_animation
    mode: single
    then:
      - if:
          condition:
            lambda: |-
              if (!id(aura_assets_ready)) return false;
              if (id(aura_music_mode)) return false;
              if (id(aura_sleeping)) return false;
              if (id(aura_speaking)) return false;
              if (id(aura_animation_running)) return false;
              if (id(${voice_assistant_phase_global_id}) != ${voice_assist_idle_phase_id}) return false;
              if (id(${display_emotion_mode_id}) != 0) return false;
              return true;
          then:
            - lambda: |-
                id(aura_animation_running) = true;
                id(aura_random_action) = esp_random() % 100;

            - if:
                condition:
                  lambda: return id(aura_random_action) < 18;
                then:
                  - lvgl.image.update:
                      id: aura_main_image
                      src: aura_left_eyes_img
                  - delay: 900ms

            - if:
                condition:
                  lambda: return id(aura_random_action) >= 18 && id(aura_random_action) < 36;
                then:
                  - lvgl.image.update:
                      id: aura_main_image
                      src: aura_right_eyes_img
                  - delay: 900ms

            - if:
                condition:
                  lambda: return id(aura_random_action) >= 36 && id(aura_random_action) < 48;
                then:
                  - lvgl.image.update:
                      id: aura_main_image
                      src: aura_up_eyes_img
                  - delay: 850ms

            - if:
                condition:
                  lambda: return id(aura_random_action) >= 48 && id(aura_random_action) < 60;
                then:
                  - lvgl.image.update:
                      id: aura_main_image
                      src: aura_left_eyes_img
                  - delay: 1300ms

            - if:
                condition:
                  lambda: return id(aura_random_action) >= 60 && id(aura_random_action) < 72;
                then:
                  - lvgl.image.update:
                      id: aura_main_image
                      src: aura_right_eyes_img
                  - delay: 1300ms

            - if:
                condition:
                  lambda: return id(aura_random_action) >= 72 && id(aura_random_action) < 80;
                then:
                  - lvgl.image.update:
                      id: aura_main_image
                      src: aura_face_up_img
                  - delay: 1100ms

            - if:
                condition:
                  lambda: return id(aura_random_action) >= 80 && id(aura_random_action) < 88;
                then:
                  - lvgl.image.update:
                      id: aura_main_image
                      src: aura_face_down_img
                  - delay: 1100ms

            - if:
                condition:
                  lambda: return id(aura_random_action) >= 88;
                then:
                  - lvgl.image.update:
                      id: aura_main_image
                      src: aura_half_smile_img
                  - delay: 320ms

            - lvgl.image.update:
                id: aura_main_image
                src: aura_idle_standby_img

            - lambda: |-
                id(aura_animation_running) = false;
                id(aura_next_expression_ms) =
                  millis() + 18000UL + (esp_random() % 27001UL);

  # ======================================================
  # AURA - AVVIO / FINE PARLATO
  # ======================================================
  - id: aura_start_speaking
    mode: restart
    then:
      - script.execute: aura_wake_up
      - script.execute: aura_stop_music
      - if:
          condition:
            lambda: return id(aura_assets_ready);
          then:
            - script.stop: aura_blink
            - script.stop: aura_random_idle_animation
            - lambda: |-
                id(aura_speaking) = true;
                id(aura_animation_running) = true;
                id(aura_blink_running) = false;
                id(aura_speaking_frame) = 0;
                id(aura_last_speaking_frame) = -1;
                id(aura_mouth_smooth) = 0.0f;
            - lvgl.page.show:
                id: aura_page
                animation: FADE_IN
                time: 120ms
            # La bocca resta chiusa finché playback_peak non rileva la voce.
            - lvgl.image.update:
                id: aura_main_image
                src: aura_idle_standby_img

  - id: aura_stop_speaking
    mode: restart
    then:
      - if:
          condition:
            lambda: return id(aura_speaking);
          then:
            - lambda: |-
                id(aura_speaking) = false;
                id(aura_animation_running) = false;
                id(aura_blink_running) = false;
                id(aura_speaking_frame) = 0;
                id(aura_last_speaking_frame) = -1;
                id(aura_mouth_smooth) = 0.0f;
                id(aura_next_blink_ms) =
                  millis() + 2500UL + (esp_random() % 3501UL);
                id(aura_next_expression_ms) =
                  millis() + 12000UL + (esp_random() % 12001UL);

  # ======================================================
  # AURA - BLINK DURANTE LA MUSICA
  # Usa gli stessi frame online del blink naturale.
  # ======================================================
  - id: aura_music_blink
    mode: single
    then:
      - if:
          condition:
            lambda: return id(aura_music_mode) && id(aura_assets_ready);
          then:
            - lambda: id(aura_music_blinking) = true;

            - lvgl.image.update:
                id: aura_main_image
                src: aura_blink_half_closed_img
            - delay: 55ms

            - if:
                condition:
                  lambda: return id(aura_music_mode);
                then:
                  - lvgl.image.update:
                      id: aura_main_image
                      src: aura_blink_closed_img
            - delay: 75ms

            - if:
                condition:
                  lambda: return id(aura_music_mode);
                then:
                  - lvgl.image.update:
                      id: aura_main_image
                      src: aura_blink_half_closed_img
            - delay: 55ms

            - lambda: |-
                id(aura_music_blinking) = false;
                id(aura_music_next_pose_ms) = millis();

  # ======================================================
  # AURA - SCEGLIE UNA POSA MUSICALE CASUALE
  # 82% Dance, 10% idle, 8% blink naturale.
  # 2 immagini Dance disponibili.
  # ======================================================
  - id: aura_music_next_pose
    mode: restart
    then:
      - if:
          condition:
            lambda: |-
              return id(aura_music_mode) &&
                     id(aura_assets_ready) &&
                     !id(aura_music_blinking);
          then:
            - lambda: |-
                const uint32_t now = millis();
                const uint32_t choice = esp_random() % 100U;
                int pose = 0;
  
                if (choice < 82U) {
                  // Pose Dance disponibili: 1, 2 e 3.
                  do {
                    pose = 1 + (esp_random() % 3U);
                  } while (pose == id(aura_music_last_pose));  
                } else if (choice < 92U) {
                  pose = 0;  // breve ritorno all'idle
  
                } else {
                  pose = 4;  // blink
                }
  
                id(aura_music_pose) = pose;
  
                // Memorizza esclusivamente l'ultima posa Dance.
                if (pose == 1 || pose == 2 || pose == 3) {
                  id(aura_music_last_pose) = pose;
                }
  
                if (pose != 4) {
                  // Più il brano è energico, più rapidamente cambia posa.
                  uint32_t base = 390U;
                  uint32_t reduction =
                      (uint32_t)(id(aura_music_level) * 130.0f);
  
                  uint32_t jitter = esp_random() % 210U;
                  uint32_t duration = base - reduction + jitter;
  
                  if (pose == 0) {
                    duration += 220U;
                  }
  
                  if (duration < 220U) {
                    duration = 220U;
                  }
  
                  id(aura_music_next_pose_ms) = now + duration;
  
                } else {
                  id(aura_music_next_pose_ms) = now + 450U;
                }
  
            - if:
                condition:
                  lambda: return id(aura_music_pose) == 0;
                then:
                  - lvgl.image.update:
                      id: aura_main_image
                      src: aura_idle_standby_img
  
            - if:
                condition:
                  lambda: return id(aura_music_pose) == 1;
                then:
                  - lvgl.image.update:
                      id: aura_main_image
                      src: aura_dance_01_img
  
            - if:
                condition:
                  lambda: return id(aura_music_pose) == 2;
                then:
                  - lvgl.image.update:
                      id: aura_main_image
                      src: aura_dance_02_img

            - if:
                condition:
                  lambda: return id(aura_music_pose) == 3;
                then:
                  - lvgl.image.update:
                      id: aura_main_image
                      src: aura_dance_03_img

            - if:
                condition:
                  lambda: return id(aura_music_pose) == 4;
                then:
                  - script.execute: aura_music_blink

  # ======================================================
  # AURA - MODALITA MUSICA
  # Aura resta visibile; orario e timer vengono sostituiti
  # da note danzanti, pose online e VU meter circolare.
  # ======================================================
  - id: aura_start_music
    mode: restart
    then:
      - script.execute: aura_wake_up
      - if:
          condition:
            lambda: |-
              const auto state = id(${media_player_id}).state;
              const int phase = id(${voice_assistant_phase_global_id});

              return id(aura_assets_ready) &&
                     state == media_player::MediaPlayerState::MEDIA_PLAYER_STATE_PLAYING &&
                     !id(${timer_ringing_switch_id}).state &&
                     !id(${va_timer_active_display_id}) &&
                     !id(aura_speaking) &&
                     phase != ${voice_assist_waiting_for_command_phase_id} &&
                     phase != ${voice_assist_listening_for_command_phase_id} &&
                     phase != ${voice_assist_thinking_phase_id} &&
                     phase != ${voice_assist_replying_phase_id};
          then:
            - script.stop: aura_blink
            - script.stop: aura_random_idle_animation
            - lambda: |-
                id(aura_music_mode) = true;
                id(aura_music_level) = 0.0f;
                id(aura_music_pose) = 0;
                id(aura_music_last_pose) = -1;
                id(aura_music_next_pose_ms) = millis();
                id(aura_music_blinking) = false;
                id(aura_animation_running) = false;
                id(aura_blink_running) = false;
                id(${display_awake_until_id}) = millis() + 300000UL;

            - lvgl.page.show:
                id: aura_page
                animation: FADE_IN
                time: 140ms

            - lvgl.image.update:
                id: aura_main_image
                src: aura_dance_01_img

            - lvgl.label.update:
                id: aura_status_label
                text: "MUSICA"
                text_color: 0xBFFFEA

            - lvgl.widget.hide: aura_time_plate
            - lvgl.widget.hide: aura_time_label
            - lvgl.widget.hide: aura_timer_plate
            - lvgl.widget.hide: aura_timer_label
            - lvgl.widget.hide: aura_timer_bar
            # Lo swipe verso l'alto resta disponibile anche durante la musica.
            - lvgl.widget.show: aura_music_vu_arc
            - lvgl.widget.show: aura_music_note_1
            - lvgl.widget.show: aura_music_note_2
            - lvgl.widget.show: aura_music_note_3
            - lvgl.widget.show: aura_music_note_4
            - lvgl.widget.show: aura_music_note_5
            - lvgl.widget.show: aura_music_note_6
            - script.execute: aura_music_next_pose

  - id: aura_stop_music
    mode: restart
    then:
      - if:
          condition:
            lambda: return id(aura_music_mode);
          then:
            - script.stop: aura_music_blink
            - script.stop: aura_music_next_pose
            - lambda: |-
                id(aura_music_mode) = false;
                id(aura_music_level) = 0.0f;
                id(aura_music_pose) = 0;
                id(aura_music_last_pose) = -1;
                id(aura_music_next_pose_ms) = 0;
                id(aura_music_blinking) = false;
                id(aura_next_blink_ms) =
                  millis() + 2500UL + (esp_random() % 3501UL);
                id(aura_next_expression_ms) =
                  millis() + 12000UL + (esp_random() % 12001UL);

            - lvgl.arc.update:
                id: aura_music_vu_arc
                value: 0
                indicator:
                  arc_color: 0x00DC78

            - lvgl.widget.hide: aura_music_vu_arc
            - lvgl.widget.hide: aura_music_note_1
            - lvgl.widget.hide: aura_music_note_2
            - lvgl.widget.hide: aura_music_note_3
            - lvgl.widget.hide: aura_music_note_4
            - lvgl.widget.hide: aura_music_note_5
            - lvgl.widget.hide: aura_music_note_6
            - lvgl.widget.update:
                id: aura_main_image
                x: 0
                y: 0
            - script.execute: aura_apply_phase
            - script.execute: aura_refresh_runtime_ui

  # ======================================================
  # AURA - REGISTRA ATTIVITA E RISVEGLIA
  # ======================================================
  - id: aura_register_activity
    mode: restart
    then:
      - lambda: |-
          id(aura_last_activity_ms) = millis();
      - script.execute: aura_wake_up

  # ======================================================
  # AURA - ENTRA NEL SONNO
  # ======================================================
  - id: aura_go_to_sleep
    mode: single
    then:
      - if:
          condition:
            lambda: |-
              const auto state = id(${media_player_id}).state;
              return id(aura_assets_ready) &&
                     id(aura_boot_finished) &&
                     !id(aura_sleeping) &&
                     !id(aura_music_mode) &&
                     !id(aura_speaking) &&
                     !id(${noise_detected_binary_sensor_id}).state &&
                     !id(${timer_ringing_switch_id}).state &&
                     !id(${va_timer_active_display_id}) &&
                     id(${display_emotion_mode_id}) == 0 &&
                     id(${voice_assistant_phase_global_id}) == ${voice_assist_idle_phase_id} &&
                     state != media_player::MediaPlayerState::MEDIA_PLAYER_STATE_PLAYING &&
                     state != media_player::MediaPlayerState::MEDIA_PLAYER_STATE_ANNOUNCING;
          then:
            - script.stop: aura_blink
            - script.stop: aura_random_idle_animation
            - lambda: |-
                id(aura_sleeping) = true;
                id(aura_animation_running) = false;
                id(aura_blink_running) = false;
            # Il GC9A01A originale non espone un PWM di backlight:
            # l'attenuazione viene ottenuta con aura_sleep_dim.

            - lvgl.image.update:
                id: aura_main_image
                src: aura_blink_closed_img

            - lvgl.label.update:
                id: aura_status_label
                text: "Zzz..."
                text_color: 0xB9C7FF

            - lvgl.widget.show: aura_sleep_dim
            - lvgl.widget.show: aura_sleep_z_1
            - lvgl.widget.show: aura_sleep_z_2
            - lvgl.widget.show: aura_sleep_z_3
            - lvgl.widget.show: aura_sleep_z_4

            # L'orologio resta visibile anche durante il sonno.
            - lvgl.widget.show: aura_time_plate
            - lvgl.widget.show: aura_time_label
            - lvgl.widget.hide: aura_timer_plate
            - lvgl.widget.hide: aura_timer_label
            - lvgl.widget.hide: aura_timer_bar
            - lvgl.arc.update:
                id: aura_outer_arc_1
                arc_color: 0x334155
            - lvgl.arc.update:
                id: aura_outer_arc_2
                arc_color: 0x334155
            - lvgl.arc.update:
                id: aura_outer_arc_3
                arc_color: 0x334155
            - lvgl.arc.update:
                id: aura_outer_arc_4
                arc_color: 0x334155

  # ======================================================
  # AURA - RISVEGLIO
  # ======================================================
  - id: aura_wake_up
    mode: restart
    then:
      - if:
          condition:
            lambda: return id(aura_sleeping);
          then:
            - lambda: |-
                id(aura_sleeping) = false;
                id(aura_last_activity_ms) = millis();
                id(aura_next_blink_ms) =
                  millis() + 2500UL + (esp_random() % 3501UL);
                id(aura_next_expression_ms) =
                  millis() + 12000UL + (esp_random() % 12001UL);

            - lvgl.widget.hide: aura_sleep_dim
            - lvgl.widget.hide: aura_sleep_z_1
            - lvgl.widget.hide: aura_sleep_z_2
            - lvgl.widget.hide: aura_sleep_z_3
            - lvgl.widget.hide: aura_sleep_z_4
            - script.execute: aura_apply_phase
            - script.execute: aura_refresh_runtime_ui

  # ======================================================
  # AURA - APPLICA FASE VOICE ASSISTANT / EMOZIONE
  # ======================================================
  - id: aura_apply_phase
    mode: restart
    then:
      - if:
          condition:
            lambda: return !id(aura_assets_ready);
          then:
            - lvgl.label.update:
                id: aura_boot_status
                text: "Download asset Aura..."
          else:
            - lambda: |-
                id(aura_last_phase) = id(${voice_assistant_phase_global_id});

            - if:
                condition:
                  lambda: return id(${timer_ringing_switch_id}).state;
                then:
                  - script.stop: aura_blink
                  - script.stop: aura_random_idle_animation
                  - script.execute: aura_stop_speaking
                  - lvgl.label.update:
                      id: aura_status_label
                      text: "TIMER SCADUTO"
                      text_color: 0xFFFFFF
                  - lvgl.arc.update:
                      id: aura_outer_arc_1
                      arc_color: 0xFF4038
                  - lvgl.arc.update:
                      id: aura_outer_arc_2
                      arc_color: 0xFF4038
                  - lvgl.arc.update:
                      id: aura_outer_arc_3
                      arc_color: 0xFF4038
                  - lvgl.arc.update:
                      id: aura_outer_arc_4
                      arc_color: 0xFF4038
                else:
                  - if:
                      condition:
                        lambda: return id(${voice_assistant_phase_global_id}) == ${voice_assist_replying_phase_id};
                      then:
                        - lvgl.label.update:
                            id: aura_status_label
                            text: "TI RISPONDO"
                            text_color: 0xFFD4FF
                        - lvgl.arc.update:
                            id: aura_outer_arc_1
                            arc_color: 0xFF4FD8
                        - lvgl.arc.update:
                            id: aura_outer_arc_2
                            arc_color: 0xFF4FD8
                        - lvgl.arc.update:
                            id: aura_outer_arc_3
                            arc_color: 0xFF4FD8
                        - lvgl.arc.update:
                            id: aura_outer_arc_4
                            arc_color: 0xFF4FD8
                        - script.execute: aura_start_speaking
                      else:
                        - script.execute: aura_stop_speaking
                        - script.stop: aura_blink
                        - script.stop: aura_random_idle_animation

                        - if:
                            condition:
                              lambda: return id(${voice_assistant_phase_global_id}) == ${voice_assist_waiting_for_command_phase_id};
                            then:
                              - lvgl.image.update:
                                  id: aura_main_image
                                  src: aura_idle_standby_img
                              - lvgl.label.update:
                                  id: aura_status_label
                                  text: "DIMMI..."
                                  text_color: 0xCFFBFF
                              - lvgl.arc.update:
                                  id: aura_outer_arc_1
                                  arc_color: 0x00E5FF
                              - lvgl.arc.update:
                                  id: aura_outer_arc_2
                                  arc_color: 0x00E5FF
                              - lvgl.arc.update:
                                  id: aura_outer_arc_3
                                  arc_color: 0x00E5FF
                              - lvgl.arc.update:
                                  id: aura_outer_arc_4
                                  arc_color: 0x00E5FF

                        - if:
                            condition:
                              lambda: return id(${voice_assistant_phase_global_id}) == ${voice_assist_listening_for_command_phase_id};
                            then:
                              - lvgl.image.update:
                                  id: aura_main_image
                                  src: aura_face_up_img
                              - lvgl.label.update:
                                  id: aura_status_label
                                  text: "TI ASCOLTO"
                                  text_color: 0xC8FFE0
                              - lvgl.arc.update:
                                  id: aura_outer_arc_1
                                  arc_color: 0x22C55E
                              - lvgl.arc.update:
                                  id: aura_outer_arc_2
                                  arc_color: 0x22C55E
                              - lvgl.arc.update:
                                  id: aura_outer_arc_3
                                  arc_color: 0x22C55E
                              - lvgl.arc.update:
                                  id: aura_outer_arc_4
                                  arc_color: 0x22C55E

                        - if:
                            condition:
                              lambda: return id(${voice_assistant_phase_global_id}) == ${voice_assist_thinking_phase_id};
                            then:
                              - lvgl.image.update:
                                  id: aura_main_image
                                  src: aura_up_eyes_img
                              - lvgl.label.update:
                                  id: aura_status_label
                                  text: "STO PENSANDO"
                                  text_color: 0xE9D5FF
                              - lvgl.arc.update:
                                  id: aura_outer_arc_1
                                  arc_color: 0xA855F7
                              - lvgl.arc.update:
                                  id: aura_outer_arc_2
                                  arc_color: 0xA855F7
                              - lvgl.arc.update:
                                  id: aura_outer_arc_3
                                  arc_color: 0xA855F7
                              - lvgl.arc.update:
                                  id: aura_outer_arc_4
                                  arc_color: 0xA855F7

                        - if:
                            condition:
                              lambda: return id(${voice_assistant_phase_global_id}) == ${voice_assist_error_phase_id};
                            then:
                              - lvgl.image.update:
                                  id: aura_main_image
                                  src: aura_face_down_img
                              - lvgl.label.update:
                                  id: aura_status_label
                                  text: "ERRORE"
                                  text_color: 0xFFD1D1
                              - lvgl.arc.update:
                                  id: aura_outer_arc_1
                                  arc_color: 0xEF4444
                              - lvgl.arc.update:
                                  id: aura_outer_arc_2
                                  arc_color: 0xEF4444
                              - lvgl.arc.update:
                                  id: aura_outer_arc_3
                                  arc_color: 0xEF4444
                              - lvgl.arc.update:
                                  id: aura_outer_arc_4
                                  arc_color: 0xEF4444

                        - if:
                            condition:
                              lambda: return id(${voice_assistant_phase_global_id}) == ${voice_assist_not_ready_phase_id};
                            then:
                              - lvgl.image.update:
                                  id: aura_main_image
                                  src: aura_idle_standby_img
                              - lvgl.label.update:
                                  id: aura_status_label
                                  text: "NON CONNESSA"
