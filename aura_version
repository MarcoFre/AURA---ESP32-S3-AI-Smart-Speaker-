  # ======================================================
  # AURA - TIMER, CONNESSIONI E CONTROLLI
  # ======================================================
  - id: aura_refresh_runtime_ui
    mode: restart
    then:
      - lvgl.label.update:
          id: aura_time_label
          text: !lambda |-
            auto now = id(${rtc_id}).now();
            if (!now.is_valid()) {
              return std::string("--:--");
            }
            char buf[8];
            snprintf(buf, sizeof(buf), "%02d:%02d", now.hour, now.minute);
            return std::string(buf);

      - if:
          condition:
            lambda: return id(aura_sleeping);
          then:
            - lvgl.widget.show: aura_time_plate
            - lvgl.widget.show: aura_time_label
            - lvgl.widget.hide: aura_timer_plate
            - lvgl.widget.hide: aura_timer_label
            - lvgl.widget.hide: aura_timer_bar
          else:
            - if:
                condition:
                  lambda: return id(aura_music_mode);
                then:
                  - lvgl.widget.hide: aura_time_plate
                  - lvgl.widget.hide: aura_time_label
                  - lvgl.widget.hide: aura_timer_plate
                  - lvgl.widget.hide: aura_timer_label
                  - lvgl.widget.hide: aura_timer_bar
                else:
                  - if:
                      condition:
                        lambda: return id(${va_timer_active_display_id}) || id(${timer_ringing_switch_id}).state;
                      then:
                        - lvgl.widget.hide: aura_time_plate
                        - lvgl.widget.hide: aura_time_label
                        - lvgl.widget.show: aura_timer_plate
                        - lvgl.widget.show: aura_timer_label
                        - lvgl.widget.show: aura_timer_bar
                        - lvgl.label.update:
                            id: aura_timer_label
                            text: !lambda |-
                              if (id(${timer_ringing_switch_id}).state) {
                                return std::string("TIMER!");
                              }
                              uint32_t s = id(${va_timer_seconds_left_id});
                              char buf[24];
                              if (s >= 3600UL) {
                                snprintf(buf, sizeof(buf), "%02lu:%02lu:%02lu",
                                         (unsigned long)(s / 3600UL),
                                         (unsigned long)((s % 3600UL) / 60UL),
                                         (unsigned long)(s % 60UL));
                              } else {
                                snprintf(buf, sizeof(buf), "%02lu:%02lu",
                                         (unsigned long)(s / 60UL),
                                         (unsigned long)(s % 60UL));
                              }
                              return std::string(buf);
                        - lvgl.bar.update:
                            id: aura_timer_bar
                            value: !lambda |-
                              uint32_t total = id(${va_timer_total_seconds_id});
                              uint32_t left = id(${va_timer_seconds_left_id});
                              if (id(${timer_ringing_switch_id}).state) return 100;
                              if (total == 0) return 0;
                              int pct = (int)((left * 100UL) / total);
                              if (pct < 0) pct = 0;
                              if (pct > 100) pct = 100;
                              return pct;
                      else:
                        - lvgl.widget.show: aura_time_plate
                        - lvgl.widget.show: aura_time_label
                        - lvgl.widget.hide: aura_timer_plate
                        - lvgl.widget.hide: aura_timer_label
                        - lvgl.widget.hide: aura_timer_bar

      - lvgl.widget.update:
          id: aura_wifi_dot
          bg_color: !lambda |-
            return id(${wifi_component_id}).is_connected()
              ? lv_color_hex(0x22C55E)
              : lv_color_hex(0xEF4444);

      - lvgl.widget.update:
          id: aura_api_dot
          bg_color: !lambda |-
            return id(${api_component_id}).is_connected()
              ? lv_color_hex(0x22C55E)
              : lv_color_hex(0xF59E0B);

