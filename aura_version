  - id: ${script_ensure_wake_word_running_id}
    mode: restart
    then:
      - delay: 800ms

      - if:
          condition:
            and:
              - api.connected:
              - voice_assistant.connected:
              - switch.is_off: ${mic_mute_switch_id}
              - switch.is_off: ${timer_ringing_switch_id}
              - not:
                  voice_assistant.is_running:
              - lambda: |-
                  return !id(${wake_word_flow_active_id});
              - lambda: |-
                  const auto s = id(${media_player_id}).state;
                  return s != media_player::MediaPlayerState::MEDIA_PLAYER_STATE_PLAYING &&
                         s != media_player::MediaPlayerState::MEDIA_PLAYER_STATE_ANNOUNCING;
          then:
            - if:
                condition:
                  micro_wake_word.is_running:
                then:
                  - logger.log:
                      level: INFO
                      format: "==== MWW: gia attivo"
                else:
                  - logger.log:
                      level: INFO
                      format: "==== MWW: START sicuro"
                  - micro_wake_word.start:
          else:
            - logger.log:
                level: INFO
                format: "==== MWW: start saltato, condizioni non pronte"

  - id: ${script_ring_timer_id}
    then:
      - script.execute: ${script_enable_repeat_one_id}
      - script.execute:
          id: ${script_play_sound_id}
          priority: true
          sound_file: !lambda return id(${timer_finished_sound_id});

  - id: ${script_enable_repeat_one_id}
    then:
      - lambda: |-
          id(${media_player_id})
            ->make_call()
            .set_command(media_player::MediaPlayerCommand::MEDIA_PLAYER_COMMAND_REPEAT_ONE)
            .set_announcement(true)
            .perform();
          id(${media_player_id})->set_playlist_delay_ms(speaker::AudioPipelineType::ANNOUNCEMENT, 500);

  - id: ${script_disable_repeat_id}
    then:
      - lambda: |-
          id(${media_player_id})
            ->make_call()
            .set_command(media_player::MediaPlayerCommand::MEDIA_PLAYER_COMMAND_REPEAT_OFF)
            .set_announcement(true)
            .perform();
          id(${media_player_id})->set_playlist_delay_ms(speaker::AudioPipelineType::ANNOUNCEMENT, 0);

  - id: ${script_play_sound_id}
    parameters:
      priority: bool
      sound_file: "audio::AudioFile*"
    then:
      - lambda: |-
          if (priority) {
            id(${media_player_id})
              ->make_call()
              .set_command(media_player::MediaPlayerCommand::MEDIA_PLAYER_COMMAND_STOP)
              .set_announcement(true)
              .perform();
          }
          if ((id(${media_player_id}).state != media_player::MediaPlayerState::MEDIA_PLAYER_STATE_ANNOUNCING) || priority) {
            id(${media_player_id})->play_file(sound_file, true, false);
          }

  - id: ${script_fetch_first_active_timer_id}
    mode: single
    then:
      - lambda: |-
          static uint32_t last_fetch_time = 0;
          uint32_t now = millis();
          if (now - last_fetch_time < 500) return;
          last_fetch_time = now;

          const auto &timers = id(${voice_assistant_id}).get_timers();
          if (timers.empty()) return;

          auto output_timer = *timers.begin();
          for (const auto &timer : timers) {
            if (timer.is_active && timer.seconds_left <= output_timer.seconds_left) {
              output_timer = timer;
            }
          }
          id(${first_active_timer_id}) = output_timer;

  - id: ${script_check_if_timers_active_id}
    then:
      - lambda: |-
          const auto &timers = id(${voice_assistant_id}).get_timers();
          bool output = false;
          if (!timers.empty()) {
            for (const auto &timer : timers) {
              if (timer.is_active) {
                output = true;
                break;
              }
            }
          }
          id(${is_timer_active_id}) = output;

  - id: ${script_activate_stop_word_once_id}
