        - logger.log:
            level: INFO
            format: "==== API: VoiceAssistant STOP"


    - action: set_alarm_time
      variables:
        alarm_time_hh_mm: string
      then:
        - logger.log:
            level: INFO
            format: "==== API: SET ALARM"
        - lambda: |-
            if (alarm_time_hh_mm.length() == 5 &&
                isdigit(alarm_time_hh_mm[0]) && isdigit(alarm_time_hh_mm[1]) &&
                isdigit(alarm_time_hh_mm[3]) && isdigit(alarm_time_hh_mm[4])) {
              id(${alarm_time_text_id}).publish_state(alarm_time_hh_mm);
              id(${saved_alarm_time_id}) = alarm_time_hh_mm;
            }

    - action: set_time_zone
      variables:
        posix_time_zone: string
      then:
        - logger.log:
            level: INFO
            format: "==== API: SET TIME ZONE"
        - lambda: |-
            setenv("TZ", posix_time_zone.c_str(), 1);
            tzset();
            id(${saved_time_zone_id}) = posix_time_zone;
            id(${script_publish_current_time_id}).execute();

  on_client_connected:
    - logger.log:
        level: INFO
        format: "==== API: CONNECTED"
    - lambda: id(aura_boot_progress_error) = false;
    - script.execute: aura_refresh_boot_progress
    - script.execute:
        id: ${script_play_sound_id}
        priority: true
        sound_file: !lambda return id(${wake_word_triggered_sound_id});
    - delay: 1500ms
    - script.execute: ${script_ensure_wake_word_running_id}
    - lambda: |-
        id(${voice_assistant_phase_global_id}) = ${voice_assist_idle_phase_id};
    - script.execute: aura_try_finish_boot
    - delay: 100ms

  on_client_disconnected:
    - logger.log:
        level: INFO
        format: "==== API: DISCONNECTED"
    - script.execute: aura_refresh_boot_progress
    - if:
        condition:
          lambda: return !id(aura_boot_finished);
        then:
          - lvgl.label.update:
              id: aura_boot_status
              text: "In attesa di Home Assistant..."
              text_color: 0x8FD7FF

ota:
  - platform: esphome
    id: ${ota_component_id}
    password: ${ota_key}

external_components:
  - source:
      type: git
      url: https://github.com/sw3Dan/waveshare-s2-audio_esphome_voice
      ref: main
    components: [ es8311 ]
    refresh: 0s

# ======================================================
# I2C e TCA9555
# ======================================================
i2c:
  - id: ${i2c_bus_id}
    sda: ${i2c_sda}
    scl: ${i2c_scl}
    scan: true
    frequency: 100kHz

tca9555:
  id: ${io_expander_id}
  i2c_id: ${i2c_bus_id}
  address: 0x20

# ======================================================
# LED RING WS2812 - hardware originale
# ======================================================
light:
  - platform: esp32_rmt_led_strip
    id: ${status_ring_id}
    name: "Anello LED"
    pin: ${led_pin}
    num_leds: ${led_num}
    chipset: WS2812
    rgb_order: RGB
    default_transition_length: 0ms
    restore_mode: ALWAYS_OFF
    effects:
      # ==================================================
      # AURA SYNC
      # - replica sui 7 WS2812 i quattro segmenti LVGL;
      # - usa gli stessi colori delle fasi Voice Assistant;
      # - durante la musica usa la stessa palette dei quattro archi;
      # - sui beat forti produce un breve flash bianco;
      # - durante il boot mostra una cometa azzurra.
      # ==================================================
      - addressable_lambda:
          name: "Aura Sync"
          update_interval: 50ms
          lambda: |-
            const uint32_t now = millis();
            const int count = it.size();
            if (count <= 0) return;

            auto clampf = [](float v, float lo, float hi) -> float {
              if (v < lo) return lo;
              if (v > hi) return hi;
              return v;
            };

            auto angular_distance = [](float a, float b) -> float {
              float d = fmodf(a - b + 540.0f, 360.0f) - 180.0f;
              return fabsf(d);
            };

            auto scale_color = [&](uint32_t rgb, float level) -> Color {
              level = clampf(level, 0.0f, 1.0f);
              const uint8_t r = (rgb >> 16) & 0xFF;
              const uint8_t g = (rgb >> 8)  & 0xFF;
              const uint8_t b = rgb & 0xFF;
              return Color(
                (uint8_t)(r * level + 0.5f),
                (uint8_t)(g * level + 0.5f),
                (uint8_t)(b * level + 0.5f)
              );
            };

            // Flash volume: non interrompe l'effetto e non spegne l'anello.
            if ((int32_t)(id(aura_led_flash_until) - now) > 0) {
              const float pulse =
                0.78f + 0.22f * ((sinf(now / 18.0f) + 1.0f) * 0.5f);
              for (int i = 0; i < count; i++) {
                it[i] = scale_color(0xFFFFFF, pulse);
              }
              return;
            }

            // Boot: una cometa azzurra gira sull'anello fisico mentre sul
            // display ruotano i satelliti di inizializzazione.
            if (!id(aura_boot_finished)) {
              const int head = (now / 115UL) % count;
              for (int i = 0; i < count; i++) {
                int distance = (head - i + count) % count;
                float level = 0.025f;
                if      (distance == 0) level = 0.95f;
                else if (distance == 1) level = 0.38f;
                else if (distance == 2) level = 0.12f;
                it[i] = scale_color(0x00B8FF, level);
              }
              return;
            }

            // Allarme reale: effetto rosso/blu immediatamente riconoscibile.
            if (id(${antifurto_alarm_in_corso_id})) {
              const bool swap = ((now / 140UL) % 2U) != 0U;
              for (int i = 0; i < count; i++) {
                const bool first_half = i < (count + 1) / 2;
                const bool red = swap ? !first_half : first_half;
                it[i] = red ? Color(255, 0, 0) : Color(0, 0, 255);
              }
              return;
            }

            // Timer scaduto: lampo rosso pulsante.
            if (id(${timer_ringing_switch_id}).state) {
              const float pulse =
                0.18f + 0.82f * ((sinf(now / 75.0f) + 1.0f) * 0.5f);
              for (int i = 0; i < count; i++) {
                it[i] = scale_color(0xFF4038, pulse);
              }
              return;
            }

            const float rotation =
              fmodf((float) id(aura_outer_ring_rotation), 360.0f);

            #if ${led_ring_reverse}
              const float direction = -1.0f;
            #else
              const float direction = 1.0f;
            #endif

            const float offset = ${led_ring_offset_deg}.0f;

            // ============================================================
            // MUSICA / BALLO
            // I quattro archi fisici mantengono angolo e palette del display.
            // Un'onda di luminosità reagisce al VU e un beat forte genera
            // un breve flash bianco sopra i colori.
            // ============================================================
            if (id(aura_music_mode)) {
              static float previous_level = 0.0f;
              static uint32_t beat_flash_until = 0;

              const float music_level =
                clampf(id(aura_music_level), 0.0f, 1.0f);

              if (music_level > 0.68f &&
                  (music_level - previous_level) > 0.10f) {
                beat_flash_until = now + 105UL;
              }
              previous_level = music_level;

              const bool beat_flash =
                (int32_t)(beat_flash_until - now) > 0;

              static const uint32_t palette[6] = {
                0x00E5FF, 0xA855F7, 0xFF4FD8,
                0xFFB900, 0x00DC78, 0x3B82F6
              };
              const int palette_base = (now / 350UL) % 6;

              for (int i = 0; i < count; i++) {
                float led_angle =
                  direction * ((360.0f * i) / count) + offset;
                while (led_angle < 0.0f)   led_angle += 360.0f;
                while (led_angle >= 360.0f) led_angle -= 360.0f;

                float best_distance = 999.0f;
                int nearest_arc = 0;

                for (int arc = 0; arc < 4; arc++) {
                  const float center =
                    fmodf(rotation + 14.0f + arc * 90.0f, 360.0f);
                  const float d = angular_distance(led_angle, center);
                  if (d < best_distance) {
                    best_distance = d;
                    nearest_arc = arc;
                  }
                }

                // I segmenti LVGL sono larghi 28 gradi; sui soli 7 LED
                // allarghiamo la coda per ottenere una rotazione fluida.
                float segment = 1.0f - clampf(best_distance / 48.0f, 0.0f, 1.0f);
                segment = segment * segment;

                const float wave =
                  (sinf(now / 80.0f + i * 1.65f) + 1.0f) * 0.5f;

                float brightness =
                  0.035f + segment * (0.34f + music_level * 0.56f) +
                  wave * (0.03f + music_level * 0.10f);

                brightness = clampf(brightness, 0.0f, 1.0f);

                const uint32_t rgb =
                  palette[(palette_base + nearest_arc) % 6];

                Color c = scale_color(rgb, brightness);

                if (beat_flash) {
                  const float white_mix = 0.70f;
                  c = Color(
                    (uint8_t)(c.r * (1.0f - white_mix) + 255.0f * white_mix),
                    (uint8_t)(c.g * (1.0f - white_mix) + 255.0f * white_mix),
                    (uint8_t)(c.b * (1.0f - white_mix) + 255.0f * white_mix)
                  );
                }

                it[i] = c;
              }
              return;
            }

            // ============================================================
            // FUNZIONAMENTO NORMALE
            // Colore identico ai quattro archi LVGL della fase corrente.
            // ============================================================
            uint32_t phase_color = 0x00E5FF;
            const int phase = id(${voice_assistant_phase_global_id});

            if (id(aura_sleeping)) {
              phase_color = 0x334155;
            } else if (phase == ${voice_assist_waiting_for_command_phase_id}) {
              phase_color = 0x00E5FF;
            } else if (phase == ${voice_assist_listening_for_command_phase_id}) {
              phase_color = 0x22C55E;
            } else if (phase == ${voice_assist_thinking_phase_id}) {
              phase_color = 0xA855F7;
            } else if (phase == ${voice_assist_replying_phase_id}) {
              phase_color = 0xFF4FD8;
            } else if (phase == ${voice_assist_error_phase_id}) {
              phase_color = 0xEF4444;
            } else if (phase == ${voice_assist_not_ready_phase_id}) {
              phase_color = 0x64748B;
            }

            for (int i = 0; i < count; i++) {
              float led_angle =
                direction * ((360.0f * i) / count) + offset;
              while (led_angle < 0.0f)    led_angle += 360.0f;
              while (led_angle >= 360.0f) led_angle -= 360.0f;

              float best_distance = 999.0f;
              for (int arc = 0; arc < 4; arc++) {
                const float center =
                  fmodf(rotation + 14.0f + arc * 90.0f, 360.0f);
                const float d = angular_distance(led_angle, center);
                if (d < best_distance) best_distance = d;
              }

              float segment =
                1.0f - clampf(best_distance / 48.0f, 0.0f, 1.0f);
              segment = segment * segment;

              float brightness = 0.025f + segment * 0.62f;

              if (id(aura_sleeping)) {
                brightness *= 0.16f;
              } else if (phase == ${voice_assist_replying_phase_id}) {
                const float voice_pulse =
                  0.72f + clampf(id(aura_mouth_smooth), 0.0f, 1.0f) * 0.28f;
                brightness *= voice_pulse;
              } else if (phase == ${voice_assist_not_ready_phase_id}) {
                brightness *= 0.45f;
              }

              it[i] = scale_color(
                phase_color,
                clampf(brightness, 0.0f, 1.0f)
              );
            }

      - addressable_lambda:
          name: "Police"
          update_interval: 120ms
          lambda: |-
            static uint8_t shift = 0;
            shift = (shift + 1) % it.size();
            for (int i = 0; i < it.size(); i++) {
              int pos = (i + shift) % it.size();
              it[i] = pos < it.size() / 2
                ? Color(255, 0, 0)
                : Color(0, 0, 255);
            }
      - pulse:
          name: "Pulse Slow"
          min_brightness: 30%
          max_brightness: 100%
          transition_length: 1000ms
          update_interval: 16ms
      - pulse:
          name: "Pulse Medium"
          min_brightness: 30%
          max_brightness: 100%
          transition_length: 600ms
          update_interval: 16ms
      - pulse:
          name: "Pulse Fast"
          min_brightness: 30%
          max_brightness: 100%
          transition_length: 300ms
          update_interval: 16ms
      - addressable_rainbow:
          name: "Rainbow Slow"
          speed: 6
          width: 7
      - addressable_color_wipe:
          name: "Wipe"

# ======================================================
# I2S AUDIO - OUT + IN con clock condivisi
# ======================================================
i2s_audio:
  - id: ${i2s_output_id}
    i2s_lrclk_pin:
      number: ${i2s_lrclk}
      allow_other_uses: true
    i2s_bclk_pin:
      number: ${i2s_bclk}
      allow_other_uses: true
    i2s_mclk_pin:
      number: ${i2s_mclk}

  - id: ${i2s_input_id}
    i2s_lrclk_pin:
      number: ${i2s_lrclk}
      allow_other_uses: true
    i2s_bclk_pin:
      number: ${i2s_bclk}
      allow_other_uses: true

# ======================================================
# AUDIO ADC - ES7210 / MICROFONO
# ======================================================
audio_adc:
  - platform: es7210
    id: ${audio_adc_id}
    i2c_id: ${i2c_bus_id}
    sample_rate: ${i2s_sample_rate}
    bits_per_sample: ${i2s_bps_mic}

# ======================================================
# AUDIO DAC - ES8311, clock master come nel codice originale
# ======================================================
audio_dac:
  - platform: es8311
    id: ${audio_dac_id}
    i2c_id: ${i2c_bus_id}
    use_mclk: true
    sample_rate: ${i2s_sample_rate}
    bits_per_sample: ${i2s_bps_spk}
    force_master: true
    mclk_multiple: ${i2s_mclk_multiple}

# ======================================================
# MICROFONO I2S - ES7210
# ======================================================
microphone:
  - platform: i2s_audio
    id: ${microphone_id}
    i2s_din_pin: ${i2s_din}
    adc_type: external
    pdm: false
    i2s_audio_id: ${i2s_input_id}
    i2s_mode: ${i2s_mode_mic}
    sample_rate: ${i2s_sample_rate}
    bits_per_sample: ${i2s_bps_mic}
    use_apll: ${i2s_use_apll}
    mclk_multiple: ${i2s_mclk_multiple}
    channel: ${mic_channel_${which_mic}}

# ======================================================
# SPEAKER PIPELINE
# ======================================================
speaker:
  - platform: i2s_audio
    id: ${hw_speaker_id}
    i2s_dout_pin: ${i2s_dout}
    i2s_audio_id: ${i2s_output_id}
    i2s_mode: ${i2s_mode_speaker}
    dac_type: external
    timeout: never
    buffer_duration: 100ms
    audio_dac: ${audio_dac_id}
    sample_rate: ${i2s_sample_rate}
    bits_per_sample: ${i2s_bps_spk}
    use_apll: ${i2s_use_apll}
    mclk_multiple: ${i2s_mclk_multiple}
    channel: mono

  - platform: mixer
    id: ${audio_mixer_speaker_id}
    output_speaker: ${hw_speaker_id}
    num_channels: 2
    source_speakers:
      - id: ${announcement_mixer_input_id}
        timeout: never
      - id: ${media_mixer_input_id}
        timeout: never

  - platform: resampler
    id: ${announcement_resampler_id}
    output_speaker: ${announcement_mixer_input_id}

  - platform: resampler
    id: ${media_resampler_id}
    output_speaker: ${media_mixer_input_id}

# ======================================================
# MEDIA PLAYER
# ======================================================
media_player:
  - platform: speaker
    id: ${media_player_id}
    name: "Media Player"

    media_pipeline:
      speaker: ${media_resampler_id}
      format: FLAC
      sample_rate: 48000
      num_channels: 1

    announcement_pipeline:
      speaker: ${announcement_resampler_id}
      format: FLAC
      sample_rate: 48000
      num_channels: 1

    volume_increment: 0.05
    volume_initial: 0.5
    volume_min: 0.05
    volume_max: 1.0

    buffer_size: 500000
    task_stack_in_psram: true

    on_announcement:
      - logger.log:
          level: INFO
          format: "==== MEDIAPLAYER: ANNUNCIO"
      - script.execute: aura_stop_music
      - lambda: |-
          id(${display_awake_until_id}) = millis() + 300000UL;
          // Se parte un annuncio e non è il timer, mostriamo la faccina parlante.
          if (!id(${timer_ringing_switch_id}).state) {
            if (id(${voice_assistant_phase_global_id}) != ${voice_assist_waiting_for_command_phase_id}) {
              id(${voice_assistant_phase_global_id}) = ${voice_assist_replying_phase_id};
            }          
          }          
      - mixer_speaker.apply_ducking:
          id: ${media_mixer_input_id}
          decibel_reduction: 0
          duration: 1s

    on_play:
      - logger.log:
          level: INFO
          format: "==== MEDIAPLAYER: PLAY"
      - lambda: |-
          id(${display_awake_until_id}) = millis() + 300000UL;

    on_pause:
      - logger.log:
          level: INFO
          format: "==== MEDIAPLAYER: PAUSE"
      - script.execute: aura_stop_music

    on_idle:
      - logger.log:
          level: INFO
          format: "==== MEDIAPLAYER: IDLE"
      - script.execute: aura_stop_music
      - script.execute: ${script_ensure_wake_word_running_id}
      - if:
          condition:
            and:
              - switch.is_off: ${timer_ringing_switch_id}
              - not:
                  voice_assistant.is_running:
              - not:
                  media_player.is_announcing: ${media_player_id}
          then:
            - mixer_speaker.apply_ducking:
                id: ${media_mixer_input_id}
                decibel_reduction: 0
                duration: 1.0s

            - logger.log:
                level: INFO
                format: "==== MEDIAPLAYER: IDLE"
            - lambda: |-
                if (!id(${voice_assistant_id}).is_running() &&
                    !id(${timer_ringing_switch_id}).state) {
                  id(${voice_assistant_phase_global_id}) = ${voice_assist_idle_phase_id};
                }
            - script.execute: aura_stop_speaking

    files:
      - id: ${mute_switch_on_sound_id}
        file: https://github.com/esphome/home-assistant-voice-pe/raw/dev/sounds/mute_switch_on.flac
      - id: ${mute_switch_off_sound_id}
        file: https://github.com/esphome/home-assistant-voice-pe/raw/dev/sounds/mute_switch_off.flac
      - id: ${timer_finished_sound_id}
        file: https://github.com/esphome/home-assistant-voice-pe/raw/dev/sounds/timer_finished.flac
      - id: ${wake_word_triggered_sound_id}
        file: https://github.com/esphome/home-assistant-voice-pe/raw/dev/sounds/wake_word_triggered.flac

# ======================================================
# VOICE ASSISTANT
# ======================================================
voice_assistant:
  id: ${voice_assistant_id}
  microphone:
    id: ${va_microphone_id}
    microphone: ${microphone_id}
    channels: $which_mic
  media_player: ${media_player_id}
  micro_wake_word: ${micro_wake_word_id}
  use_wake_word: false
  noise_suppression_level: 0
  auto_gain: 0 dbfs
  volume_multiplier: 1

  on_client_connected:
    - logger.log:
        level: INFO
        format: "==== VOICEASSISTANT: CONNECTED"
    - micro_wake_word.stop:
    - if:
        condition:
          and:
            - lambda: return id(${init_in_progress_id});
            - switch.is_on: ${mic_mute_switch_id}
        then:
          - switch.turn_off: ${mic_mute_switch_id}
    - lambda: id(${init_in_progress_id}) = false;
    - lambda: id(${voice_assistant_phase_global_id}) = ${voice_assist_idle_phase_id};
    - delay: 800ms
    - script.execute: ${script_ensure_wake_word_running_id}

  on_client_disconnected:
    - logger.log:
        level: INFO
        format: "==== VOICEASSISTANT: DISCONNECTED"
    - voice_assistant.stop:
    - lambda: id(${voice_assistant_phase_global_id}) = ${voice_assist_not_ready_phase_id};

  on_error:
    - logger.log:
        level: INFO
        format: "==== VOICEASSISTANT: ERROR"
    - if:
        condition:
          and:
            - lambda: return !id(${init_in_progress_id});
            - lambda: return code != "duplicate_wake_up_detected";
            - lambda: return code != "stt-no-text-recognized";
        then:
          - lambda: id(${voice_assistant_phase_global_id}) = ${voice_assist_error_phase_id};

  on_start:
    - logger.log:
        level: INFO
        format: "==== VOICEASSISTANT: ON_START"
    - lambda: |-
        id(${va_ultimo_input_ms_id}) = millis();
    - mixer_speaker.apply_ducking:
        id: ${media_mixer_input_id}
        decibel_reduction: 30
        duration: 0.0s

  on_listening:
    - logger.log:
        level: INFO
        format: "==== VOICEASSISTANT: LISTENING"
    - lambda: |-
        id(${voice_assistant_phase_global_id}) = ${voice_assist_waiting_for_command_phase_id};
        id(${va_ultimo_input_ms_id}) = millis();

  on_stt_vad_start:
    - logger.log:
        level: INFO
        format: "==== VOICEASSISTANT: VAD_START"
    - lambda: |-
        id(${voice_assistant_phase_global_id}) = ${voice_assist_listening_for_command_phase_id};
        id(${va_ultimo_input_ms_id}) = millis();

  on_stt_vad_end:
    - logger.log:
        level: INFO
        format: "==== VOICEASSISTANT: VAD_END"
    - lambda: |-
        id(${voice_assistant_phase_global_id}) = ${voice_assist_thinking_phase_id};
        id(${va_ultimo_input_ms_id}) = millis();

  on_intent_progress:
    - logger.log:
        level: INFO
        format: "==== VOICEASSISTANT: INTENT_PROGRESS"
    - if:
        condition:
          lambda: 'return !x.empty();'
        then:
          - script.execute: ${script_activate_stop_word_once_id}

  on_tts_start:
    - logger.log:
        level: INFO
        format: "==== VOICEASSISTANT: TTS_START"
    - lambda: |-
        id(${va_ultimo_input_ms_id}) = millis();
    - if:
        condition:
          lambda: 'return id(${voice_assistant_phase_global_id}) != ${voice_assist_replying_phase_id};'
        then:
          - script.execute: ${script_activate_stop_word_once_id}

  on_tts_end:
    - logger.log:
        level: INFO
        format: "==== VOICEASSISTANT: TTS_END"
    - script.execute:
        id: ${script_send_tts_uri_event_id}
        tts_uri: !lambda 'return x;'

  on_stt_end:
    - logger.log:
        level: INFO
        format: "==== VOICEASSISTANT: STT_END"
    - lambda: |-
        id(${va_ultimo_input_ms_id}) = millis();
        id(${local_cmd_code_id}) = 0;
    - script.execute:
        id: ${script_send_stt_text_event_id}
        stt_text: !lambda 'return x;'

    - lambda: |-
        id(${local_cmd_code_id}) = 0;
        std::string t = x;
        std::transform(t.begin(), t.end(), t.begin(),
          [](unsigned char c) { return std::tolower(c); });

        auto has = [&](const char *term) -> bool {
          return t.find(term) != std::string::npos;
        };

        // ===== modalità silenziosa =====
        if (has("$silent_mode") || has("$silent_mode_acc")) {
          id(${local_cmd_code_id}) = 1;
        // ===== volume locale =====
        } else if ((has("$up") || has("$increase")) && has("$volume")) {
          id(${local_cmd_code_id}) = 2;
        } else if ((has("$down") || has("$reduce")) && has("$volume")) {
          id(${local_cmd_code_id}) = 3;

        // ===== antifurto locale =====
        } else if ((has("$enable") || has("$allow") || has("$arm")) &&
                 has("$alarm")) {
          id(${local_cmd_code_id}) = 4;
        } else if ((has("$disable") || has("$deny") || has("$disarm")) &&
                   has("$alarm")) {
          id(${local_cmd_code_id}) = 5;
        }

    - if:
        condition:
          lambda: 'return id(${local_cmd_code_id}) == 1;'
        then:
          - media_player.stop: ${media_player_id}
    - if:
        condition:
          lambda: 'return id(${local_cmd_code_id}) == 2;'
        then:
          - script.execute: ${script_va_local_volume_up_id}

    - if:
        condition:
          lambda: 'return id(${local_cmd_code_id}) == 3;'
        then:
          - script.execute: ${script_va_local_volume_down_id}

    - if:
        condition:
          lambda: 'return id(${local_cmd_code_id}) == 4;'
        then:
          - script.execute: ${script_va_local_alarm_on_id}

    - if:
        condition:
          lambda: 'return id(${local_cmd_code_id}) == 5;'
        then:
          - script.execute: ${script_va_local_alarm_off_id}

    - if:
        condition:
          lambda: 'return id(${local_cmd_code_id}) != 0;'
        then:
          - logger.log:
              level: INFO
              format: "==== VOICEASSISTANT: LOCAL INTENT -> stop pipeline"
          - voice_assistant.stop:
          - script.execute: ${script_ensure_wake_word_running_id}
          - lambda: |-
              id(${voice_assistant_phase_global_id}) = ${voice_assist_idle_phase_id};

  on_end:
    - logger.log:
        level: INFO
        format: "==== VOICEASSISTANT: ON_END"
    - wait_until:
        not:
          voice_assistant.is_running:
    - mixer_speaker.apply_ducking:
          id: ${media_mixer_input_id}
          decibel_reduction: 0
          duration: 1.0s
    - if:
        condition:
          lambda: return id(${voice_assistant_phase_global_id}) == ${voice_assist_error_phase_id};
        then:
          - delay: 1s
    - lambda: id(${voice_assistant_phase_global_id}) = ${voice_assist_idle_phase_id};
    - script.execute: ${script_ensure_wake_word_running_id}

  on_timer_finished:
    - switch.turn_on: ${timer_ringing_switch_id}
    - lambda: |-
        id(${next_timer_sensor_id}).publish_state(-1);
        id(${next_timer_name_sensor_id}).publish_state("-");
        id(${va_timer_total_seconds_id}) = 0;
        id(${va_timer_seconds_left_id})  = 0;
        id(${va_timer_active_display_id}) = false;
    - voice_assistant.stop:
    - script.execute: ${script_ensure_wake_word_running_id}
    - lambda: |-
        id(${voice_assistant_phase_global_id}) = ${voice_assist_idle_phase_id};

  on_timer_started:
    - lambda: |-
        id(${script_check_if_timers_active_id}).execute();
        if (id(${is_timer_active_id})) {
          id(${script_fetch_first_active_timer_id}).execute();
          id(${next_timer_sensor_id}).publish_state(id(${first_active_timer_id}).seconds_left);
          id(${next_timer_name_sensor_id}).publish_state(id(${first_active_timer_id}).name);
          id(${va_timer_total_seconds_id}) = id(${first_active_timer_id}).total_seconds;
          id(${va_timer_seconds_left_id})  = id(${first_active_timer_id}).seconds_left;
          id(${va_timer_last_tick_ms_id})  = millis();
          id(${va_timer_active_display_id}) = true;
          id(${va_timer_name_display_id}) = id(${first_active_timer_id}).name;
        }
    - voice_assistant.stop: 
    - lambda: |-
        id(${voice_assistant_phase_global_id}) = ${voice_assist_idle_phase_id};
    - voice_assistant.stop:
    - script.execute: ${script_ensure_wake_word_running_id}
    - lambda: |-
        id(${voice_assistant_phase_global_id}) = ${voice_assist_idle_phase_id};

  on_timer_cancelled:
    - lambda: |-
        id(${script_check_if_timers_active_id}).execute();
        if (id(${is_timer_active_id})) {
          id(${script_fetch_first_active_timer_id}).execute();
          id(${next_timer_sensor_id}).publish_state(id(${first_active_timer_id}).seconds_left);
          id(${next_timer_name_sensor_id}).publish_state(id(${first_active_timer_id}).name);
          id(${va_timer_total_seconds_id}) = id(${first_active_timer_id}).total_seconds;
          id(${va_timer_seconds_left_id})  = id(${first_active_timer_id}).seconds_left;
          id(${va_timer_last_tick_ms_id})  = millis();
          id(${va_timer_active_display_id}) = id(${first_active_timer_id}).is_active;
          id(${va_timer_name_display_id}) = id(${first_active_timer_id}).name;
        } else {
          id(${next_timer_sensor_id}).publish_state(-1);
          id(${next_timer_name_sensor_id}).publish_state("-");
          id(${va_timer_total_seconds_id}) = 0;
          id(${va_timer_seconds_left_id})  = 0;
          id(${va_timer_active_display_id}) = false;
          id(${va_timer_name_display_id}) = "";
        }
    - voice_assistant.stop:
    - script.execute: ${script_ensure_wake_word_running_id}
    - lambda: |-
        id(${voice_assistant_phase_global_id}) = ${voice_assist_idle_phase_id};

  on_timer_updated:
    - lambda: |-
        id(${script_check_if_timers_active_id}).execute();
        if (id(${is_timer_active_id})) {
          id(${script_fetch_first_active_timer_id}).execute();
          id(${next_timer_sensor_id}).publish_state(id(${first_active_timer_id}).seconds_left);
          id(${next_timer_name_sensor_id}).publish_state(id(${first_active_timer_id}).name);
          id(${va_timer_total_seconds_id}) = id(${first_active_timer_id}).total_seconds;
          id(${va_timer_seconds_left_id})  = id(${first_active_timer_id}).seconds_left;
          id(${va_timer_last_tick_ms_id})  = millis();
          id(${va_timer_active_display_id}) = id(${first_active_timer_id}).is_active;
          id(${va_timer_name_display_id}) = id(${first_active_timer_id}).name;
        }

  on_timer_tick:
    - lambda: |-
        id(${script_fetch_first_active_timer_id}).execute();
        int seconds_left = id(${first_active_timer_id}).seconds_left;
        if (seconds_left % 5 == 0) {
          id(${next_timer_sensor_id}).publish_state(seconds_left);
        }
        id(${va_timer_seconds_left_id})  = id(${first_active_timer_id}).seconds_left;
        id(${va_timer_last_tick_ms_id})  = millis();

# ======================================================
# IMICRO WAKE WORD
# ======================================================
micro_wake_word:
  id: ${micro_wake_word_id}
  microphone: ${microphone_id}
  stop_after_detection: false
  models:
    - model: https://github.com/kahrendt/microWakeWord/releases/download/okay_nabu_20241226.3/okay_nabu.json
      id: ${wake_word_okay_nabu_model_id}
    - model: https://raw.githubusercontent.com/formatBCE/Respeaker-Lite-ESPHome-integration/refs/heads/main/microwakeword/models/v2/kenobi.json
      id: ${wake_word_kenobi_model_id}
    - model: ${wake_word_hey_jarvis_model_id}
      id: ${wake_word_hey_jarvis_model_id}
    - model: https://github.com/kahrendt/microWakeWord/releases/download/stop/stop.json
      id: ${wake_word_stop_model_id}
      internal: true

  on_wake_word_detected:
    - logger.log:
        level: INFO
        format: "==== MWW: WORD DETECTED"

    - if:
        condition:
          switch.is_off: ${mic_mute_switch_id}
        then:
          - if:
              condition:
                switch.is_on: ${timer_ringing_switch_id}
              then:
                - switch.turn_off: ${timer_ringing_switch_id}

              else:
                - if:
                    condition:
                      voice_assistant.is_running:
                    then:
                      - voice_assistant.stop:

                    else:
                      - if:
                          condition:
                            media_player.is_announcing: ${media_player_id}
                          then:
                            - media_player.stop:
                                announcement: true

                      - script.execute:
                          id: ${script_start_va_from_wake_word_id}
                          detected_wake_word: !lambda return wake_word;

