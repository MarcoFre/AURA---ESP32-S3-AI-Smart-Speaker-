interval:

  # ----------------------------------------------------
  # BOOT ANIMATION LVGL - schema identico alla fonte
  # Tre oggetti aggiornati tramite global e widget.refresh.
  # ----------------------------------------------------
  - interval: 80ms
    then:
      - if:
          condition:
            and:
              - lambda: return !id(aura_boot_finished);
              - lvgl.page.is_showing: aura_boot_page
          then:
            - lambda: |-
                const uint32_t now = millis();
                const int cx = 120;
                const int cy = 120;
                const float PI2 = 6.2831853f;

                const float a_outer =
                  ((now % 4200UL) / 4200.0f) * PI2 - 1.5707963f;

                const float a_mid =
                  ((now % 2800UL) / 2800.0f) * PI2 + 0.45f;

                const float a_inner =
                  ((now % 1800UL) / 1800.0f) * PI2 + 2.10f;

                id(aura_boot_dot_outer_x) = cx + (int)(cosf(a_outer) * 100.0f);
                id(aura_boot_dot_outer_y) = cy + (int)(sinf(a_outer) * 100.0f);

                id(aura_boot_dot_mid_x) = cx + (int)(cosf(a_mid) * 77.0f);
                id(aura_boot_dot_mid_y) = cy + (int)(sinf(a_mid) * 77.0f);

                id(aura_boot_dot_inner_x) = cx + (int)(cosf(a_inner) * 54.0f);
                id(aura_boot_dot_inner_y) = cy + (int)(sinf(a_inner) * 54.0f);

            - lvgl.widget.refresh: aura_boot_dot_outer
            - lvgl.widget.refresh: aura_boot_dot_mid
            - lvgl.widget.refresh: aura_boot_dot_inner

  # ----------------------------------------------------
  # BOOT MANAGER - aggiorna stato e apre Aura quando pronta
  # ----------------------------------------------------
  - interval: 1s
    then:
      - if:
          condition:
            lambda: return !id(aura_boot_finished);
          then:
            - script.execute: aura_try_finish_boot

  # ----------------------------------------------------
  # AURA - MOTORE MUSICA / NOTE / VU METER
  # Il livello reale arriva da playback_peak. Se il valore
  # e assente o quasi fermo viene mantenuto un lieve ritmo
  # sintetico per non congelare l'animazione.
  # ----------------------------------------------------
  - interval: 80ms
    then:
      - if:
          condition:
            lambda: |-
              const auto state = id(${media_player_id}).state;
              const int phase = id(${voice_assistant_phase_global_id});

              const bool should_music =
                id(aura_assets_ready) &&
                state == media_player::MediaPlayerState::MEDIA_PLAYER_STATE_PLAYING &&
                !id(${timer_ringing_switch_id}).state &&
                !id(${va_timer_active_display_id}) &&
                !id(aura_speaking) &&
                phase != ${voice_assist_waiting_for_command_phase_id} &&
                phase != ${voice_assist_listening_for_command_phase_id} &&
                phase != ${voice_assist_thinking_phase_id} &&
                phase != ${voice_assist_replying_phase_id};

              return should_music && !id(aura_music_mode);
          then:
            - script.execute: aura_start_music

      - if:
          condition:
            lambda: |-
              if (!id(aura_music_mode)) return false;

              const auto state = id(${media_player_id}).state;
              const int phase = id(${voice_assistant_phase_global_id});

              return state != media_player::MediaPlayerState::MEDIA_PLAYER_STATE_PLAYING ||
                     id(${timer_ringing_switch_id}).state ||
                     id(${va_timer_active_display_id}) ||
                     id(aura_speaking) ||
                     phase == ${voice_assist_waiting_for_command_phase_id} ||
                     phase == ${voice_assist_listening_for_command_phase_id} ||
                     phase == ${voice_assist_thinking_phase_id} ||
                     phase == ${voice_assist_replying_phase_id};
          then:
            - script.execute: aura_stop_music

      - if:
          condition:
            lambda: return id(aura_music_mode) && id(aura_assets_ready);
          then:
            - lambda: |-
                const uint32_t now = millis();

                float real_level = 0.0f;

                // Il sensore sound_level pubblica RMS relativo in dB:
                // 0 dB e' il massimo misurabile. Il vecchio mapping sul PEAK
                // saturava gia a -35 dB; qui il fondo scala arriva a -1 dB RMS.
                const float rms_db = id(${playback_rms_sensor_id}).state;
                if (!std::isnan(rms_db) && !std::isinf(rms_db)) {
                  constexpr float floor_db = -58.0f;
                  constexpr float full_scale_db = -1.0f;

                  float normalized =
                    (rms_db - floor_db) / (full_scale_db - floor_db);

                  if (normalized < 0.0f) normalized = 0.0f;
                  if (normalized > 1.0f) normalized = 1.0f;

                  // Curva leggermente compressa per lasciare spazio ai picchi
                  // ed evitare che il VU resti costantemente a fondo scala.
                  real_level = powf(normalized, 1.55f);

                  if (rms_db < -55.0f) {
                    real_level = 0.0f;
                  }
                }

                const float slow = (sinf(now / 310.0f) + 1.0f) * 0.5f;
                const float fast = (sinf(now / 105.0f) + 1.0f) * 0.5f;
                float pulse = sinf(now / 72.0f);
                if (pulse < 0.0f) pulse = 0.0f;
                pulse = pulse * pulse * pulse * pulse;

                const float synthetic =
                  0.10f + slow * 0.16f + fast * 0.18f + pulse * 0.38f;

                float target = real_level;
                if (target < 0.04f) {
                  target = synthetic * 0.72f;
                } else {
                  const float floor = synthetic * 0.20f;
                  if (target < floor) target = floor;
                }

                if (target > 1.0f) target = 1.0f;

                const float alpha =
                  target > id(aura_music_level) ? 0.58f : 0.14f;

                id(aura_music_level) +=
                  (target - id(aura_music_level)) * alpha;

                if (id(aura_music_level) < 0.0f) id(aura_music_level) = 0.0f;
                if (id(aura_music_level) > 1.0f) id(aura_music_level) = 1.0f;

            - lvgl.arc.update:
                id: aura_music_vu_arc
                value: !lambda |-
                  return (int)(id(aura_music_level) * 100.0f + 0.5f);
                indicator:
                  arc_color: !lambda |-
                    const float level = id(aura_music_level);
                    if (level >= 0.90f) return lv_color_hex(0xFF4614);
                    if (level >= 0.70f) return lv_color_hex(0xFFB900);
                    return lv_color_hex(0x00DC78);

            - lvgl.widget.refresh: aura_music_note_1
            - lvgl.widget.refresh: aura_music_note_2
            - lvgl.widget.refresh: aura_music_note_3
            - lvgl.widget.refresh: aura_music_note_4
            - lvgl.widget.refresh: aura_music_note_5
            - lvgl.widget.refresh: aura_music_note_6

            # Piccolo movimento continuo dell'intera immagine:
            # destra/sinistra e alto/basso, più evidente sui picchi.
            - lvgl.widget.update:
                id: aura_main_image
                x: !lambda |-
                  const float amp = 2.0f + id(aura_music_level) * 5.0f;
                  return (int)(sinf(millis() / 360.0f) * amp);
                y: !lambda |-
                  const float amp = 1.5f + id(aura_music_level) * 3.5f;
                  return -1 + (int)(sinf(millis() / 245.0f + 1.1f) * amp);

            - if:
                condition:
                  lambda: |-
                    return !id(aura_music_blinking) &&
                           millis() >= id(aura_music_next_pose_ms);
                then:
                  - script.execute: aura_music_next_pose

  # ----------------------------------------------------
  # AURA - SONNO / RISVEGLIO DOPO QUIETE
  # Rumore, media, timer, pulsanti fisici e VA mantengono Aura sveglia.
  # ----------------------------------------------------
  - interval: 250ms
    then:
      - lambda: |-
          const uint32_t now = millis();
          const auto state = id(${media_player_id}).state;
          const int phase = id(${voice_assistant_phase_global_id});

          if (id(aura_last_activity_ms) == 0) {
            id(aura_last_activity_ms) = now;
          }

          const bool active =
            !id(aura_boot_finished) ||
            id(aura_music_mode) ||
            id(aura_speaking) ||
            id(${noise_detected_binary_sensor_id}).state ||
            id(${timer_ringing_switch_id}).state ||
            id(${va_timer_active_display_id}) ||
            id(${display_emotion_mode_id}) != 0 ||
            phase != ${voice_assist_idle_phase_id} ||
            state == media_player::MediaPlayerState::MEDIA_PLAYER_STATE_PLAYING ||
            state == media_player::MediaPlayerState::MEDIA_PLAYER_STATE_ANNOUNCING;

          if (active) {
            id(aura_last_activity_ms) = now;
          }

      - if:
          condition:
            lambda: |-
              const auto state = id(${media_player_id}).state;
              const int phase = id(${voice_assistant_phase_global_id});
              const bool active =
                    id(aura_music_mode) ||
                id(aura_speaking) ||
                id(${noise_detected_binary_sensor_id}).state ||
                id(${timer_ringing_switch_id}).state ||
                id(${va_timer_active_display_id}) ||
                id(${display_emotion_mode_id}) != 0 ||
                phase != ${voice_assist_idle_phase_id} ||
                state == media_player::MediaPlayerState::MEDIA_PLAYER_STATE_PLAYING ||
                state == media_player::MediaPlayerState::MEDIA_PLAYER_STATE_ANNOUNCING;
              return id(aura_sleeping) && active;
          then:
            - script.execute: aura_wake_up

      - if:
          condition:
            lambda: |-
              if (!id(aura_assets_ready) || !id(aura_boot_finished)) return false;
              if (id(aura_sleeping)) return false;
              if (id(aura_last_activity_ms) == 0) return false;
              if ((uint32_t)(millis() - id(aura_last_activity_ms)) < id(aura_sleep_timeout_ms)) return false;

              const auto state = id(${media_player_id}).state;
              return                      !id(aura_music_mode) &&
                     !id(aura_speaking) &&
                     !id(${noise_detected_binary_sensor_id}).state &&
                     !id(${timer_ringing_switch_id}).state &&
                     !id(${va_timer_active_display_id}) &&
                     id(${display_emotion_mode_id}) == 0 &&
                     id(${voice_assistant_phase_global_id}) == ${voice_assist_idle_phase_id} &&
                     state != media_player::MediaPlayerState::MEDIA_PLAYER_STATE_PLAYING &&
                     state != media_player::MediaPlayerState::MEDIA_PLAYER_STATE_ANNOUNCING;
          then:
            - script.execute: aura_go_to_sleep

      - if:
          condition:
            lambda: return id(aura_sleeping);
          then:
            - lvgl.widget.refresh: aura_sleep_z_1
            - lvgl.widget.refresh: aura_sleep_z_2
            - lvgl.widget.refresh: aura_sleep_z_3
            - lvgl.widget.refresh: aura_sleep_z_4

  # ----------------------------------------------------
  # AURA - CAMBIO FASE / STATO TIMER
  # ----------------------------------------------------
  - interval: 100ms
    then:
      - if:
          condition:
            lambda: |-
              // Durante il boot il testo e la pagina sono gestiti dal boot manager.
              if (!id(aura_assets_ready)) return false;

              bool timer_now = id(${timer_ringing_switch_id}).state;
              bool changed =
                id(aura_last_phase) != id(${voice_assistant_phase_global_id}) ||
                id(aura_last_timer_ringing) != timer_now;
              if (changed) {
                id(aura_last_timer_ringing) = timer_now;
              }
              return changed;
          then:
            - script.execute: aura_apply_phase

  # ----------------------------------------------------
  # AURA - ROTAZIONE ANELLO ESTERNO + SINCRONIA LED FISICI
  # La variabile aura_outer_ring_rotation viene letta anche dall'effetto
  # addressable Aura Sync. Display e LED seguono quindi lo stesso angolo.
  # In musica la rotazione accelera e i quattro archi cambiano palette.
  # ----------------------------------------------------
  - interval: 125ms
    then:
      - if:
          condition:
            and:
              - lambda: return id(aura_assets_ready) && !id(aura_sleeping);
              - lvgl.page.is_showing: aura_page
          then:
            - lambda: |-
                int step = 1;

                if (id(aura_music_mode)) {
                  // Da circa 9 a 4,5 secondi per un giro completo,
                  // in funzione del livello musicale.
                  step = 5 + (int)(id(aura_music_level) * 5.0f + 0.5f);
                } else if (id(aura_speaking)) {
                  step = 2;
                }

                id(aura_outer_ring_rotation) += step;
                while (id(aura_outer_ring_rotation) >= 360) {
                  id(aura_outer_ring_rotation) -= 360;
                }

            - lvgl.arc.update:
                id: aura_outer_arc_1
                rotation: !lambda return id(aura_outer_ring_rotation);
            - lvgl.arc.update:
                id: aura_outer_arc_2
                rotation: !lambda return id(aura_outer_ring_rotation);
            - lvgl.arc.update:
                id: aura_outer_arc_3
                rotation: !lambda return id(aura_outer_ring_rotation);
            - lvgl.arc.update:
                id: aura_outer_arc_4
                rotation: !lambda return id(aura_outer_ring_rotation);

            # Durante il ballo ogni segmento assume un colore diverso della
            # stessa palette usata dall'anello WS2812.
            - if:
                condition:
                  lambda: return id(aura_music_mode);
                then:
                  - lvgl.arc.update:
                      id: aura_outer_arc_1
                      arc_color: !lambda |-
                        static const uint32_t palette[6] = {
                          0x00E5FF, 0xA855F7, 0xFF4FD8,
                          0xFFB900, 0x00DC78, 0x3B82F6
                        };
                        const int p = (millis() / 350UL) % 6;
                        return lv_color_hex(palette[p]);
                  - lvgl.arc.update:
                      id: aura_outer_arc_2
                      arc_color: !lambda |-
                        static const uint32_t palette[6] = {
                          0x00E5FF, 0xA855F7, 0xFF4FD8,
                          0xFFB900, 0x00DC78, 0x3B82F6
                        };
                        const int p = (millis() / 350UL) % 6;
                        return lv_color_hex(palette[(p + 1) % 6]);
                  - lvgl.arc.update:
                      id: aura_outer_arc_3
                      arc_color: !lambda |-
                        static const uint32_t palette[6] = {
                          0x00E5FF, 0xA855F7, 0xFF4FD8,
                          0xFFB900, 0x00DC78, 0x3B82F6
                        };
                        const int p = (millis() / 350UL) % 6;
                        return lv_color_hex(palette[(p + 2) % 6]);
                  - lvgl.arc.update:
                      id: aura_outer_arc_4
                      arc_color: !lambda |-
                        static const uint32_t palette[6] = {
                          0x00E5FF, 0xA855F7, 0xFF4FD8,
                          0xFFB900, 0x00DC78, 0x3B82F6
                        };
                        const int p = (millis() / 350UL) % 6;
                        return lv_color_hex(palette[(p + 3) % 6]);

  # ----------------------------------------------------
  # AURA - CONTROLLO BLINK
  # ----------------------------------------------------
  - interval: 500ms
    then:
      - if:
          condition:
            lambda: |-
              if (!id(aura_assets_ready)) return false;
              if (id(aura_music_mode)) return false;
              if (id(aura_sleeping)) return false;
              if (id(aura_speaking)) return false;
              if (id(aura_animation_running)) return false;
              if (id(${voice_assistant_phase_global_id}) != ${voice_assist_idle_phase_id}) return false;
              if (id(${display_emotion_mode_id}) != 0) return false;
              if (id(aura_next_blink_ms) == 0) {
                id(aura_next_blink_ms) = millis() + 6000UL + (esp_random() % 14001UL);
                return false;
              }
              return (int32_t)(millis() - id(aura_next_blink_ms)) >= 0;
          then:
            - script.execute: aura_blink

  # ----------------------------------------------------
  # AURA - ESPRESSIONI CASUALI / UI RUNTIME / TIMEOUT
  # ----------------------------------------------------
  - interval: 1s
    then:
      - script.execute: aura_refresh_runtime_ui

      - if:
          condition:
            lambda: |-
              if (!id(aura_assets_ready)) return false;
              if (id(aura_music_mode)) return false;
              if (id(aura_sleeping)) return false;
              if (id(aura_speaking)) return false;
              if (id(aura_animation_running)) return false;
              if (id(${voice_assistant_phase_global_id}) != ${voice_assist_idle_phase_id}) return false;
              if (id(${display_emotion_mode_id}) != 0) return false;
              if (id(aura_next_expression_ms) == 0) {
                id(aura_next_expression_ms) = millis() + 15000UL + (esp_random() % 15001UL);
                return false;
              }
              return (int32_t)(millis() - id(aura_next_expression_ms)) >= 0;
          then:
            - script.execute: aura_random_idle_animation

  # ----------------------------------------------------
  # AURA - BOCCA AUDIO-REATTIVA DURANTE IL PARLATO
  # Riproduce la logica della lambda originale:
  # playback_peak -> smoothing -> sillaba/frase/chiusure -> frame LVGL.
  # ----------------------------------------------------
  - interval: 70ms
    then:
      - if:
          condition:
            lambda: |-
              if (!id(aura_assets_ready)) return false;
              if (!id(aura_speaking)) return false;
              if (id(aura_music_mode)) return false;
              if (id(aura_sleeping)) return false;
              if (id(${timer_ringing_switch_id}).state) return false;
              if (id(${voice_assistant_phase_global_id}) != ${voice_assist_replying_phase_id}) return false;

              const auto mp_state = id(${media_player_id}).state;
              return mp_state == media_player::MediaPlayerState::MEDIA_PLAYER_STATE_ANNOUNCING;
          then:
            - lambda: |-
                const uint32_t now = millis();

                auto clampf = [](float v, float lo, float hi) -> float {
                  if (v < lo) return lo;
                  if (v > hi) return hi;
                  return v;
                };

                // 1) Livello reale dell'audio, stessa conversione della lambda originale.
                float mouth_level = 0.0f;
                const float db = id(${playback_peak_sensor_id}).state;

                if (!std::isnan(db)) {
                  mouth_level = clampf((db + 68.0f) / 45.0f, 0.0f, 1.0f);
                  if (db < -62.0f) {
                    mouth_level = 0.0f;
                  }
                }

                // 2) Attacco rapido, rilascio più morbido.
                id(aura_mouth_smooth) +=
                  (mouth_level > id(aura_mouth_smooth) ? 0.55f : 0.18f) *
                  (mouth_level - id(aura_mouth_smooth));

                float mouth_anim = id(aura_mouth_smooth);

                // 3) Modulazione sillabica, andamento frase e micro-chiusure labiali.
                if (mouth_anim > 0.05f) {
                  const float syllable =
                    0.50f + 0.50f * ((sinf(now / 72.0f) + 1.0f) * 0.5f);

                  const float phrase =
                    0.72f + 0.28f * ((sinf(now / 210.0f + 1.4f) + 1.0f) * 0.5f);

                  const uint32_t cc = now % 640UL;

                  float closure =
                    (cc < 70UL)  ? 0.10f :
                    (cc < 115UL) ? 0.35f :
                                   1.00f;

                  if ((now % 2300UL) > 2100UL) {
                    closure *= 0.25f;
                  }

                  mouth_anim = clampf(
                    mouth_anim * syllable * phrase * closure,
                    0.0f,
                    1.0f
                  );
                }

                // 4) Conversione del livello continuo nei cinque frame disponibili.
                int next_frame = 0;

                if (id(aura_mouth_smooth) > 0.05f) {
                  if (mouth_anim < 0.25) {
                    next_frame = 0;
                  } else if (mouth_anim < 0.50f) {
                    next_frame = 1;
                  } else if (mouth_anim < 0.75) {
                    next_frame = 2;
                  } else {
                    next_frame = 3;
                  }
                }

                id(aura_speaking_frame) = next_frame;

            # Aggiorna l'immagine soltanto quando cambia il frame.
            - if:
                condition:
                  lambda: return id(aura_speaking_frame) != id(aura_last_speaking_frame);
                then:
                  - lambda: |-
                      id(aura_last_speaking_frame) = id(aura_speaking_frame);

                  - if:
                      condition:
                        lambda: return id(aura_speaking_frame) == 0;
                      then:
                        - lvgl.image.update:
                            id: aura_main_image
                            src: aura_idle_standby_img

                  - if:
                      condition:
                        lambda: return id(aura_speaking_frame) == 1;
                      then:
                        - lvgl.image.update:
                            id: aura_main_image
                            src: aura_small_open_mouth_img

                  - if:
                      condition:
                        lambda: return id(aura_speaking_frame) == 2;
                      then:
                        - lvgl.image.update:
                            id: aura_main_image
                            src: aura_open_mouth_img

                  - if:
                      condition:
                        lambda: return id(aura_speaking_frame) == 3;
                      then:
                        - lvgl.image.update:
                            id: aura_main_image
                            src: aura_more_open_mouth_img

      # Se il parlato è terminato o l'annuncio non è più attivo,
      # scarica rapidamente il livello residuo e richiude la bocca.
      - if:
          condition:
            lambda: |-
              if (!id(aura_speaking)) return false;
              const auto mp_state = id(${media_player_id}).state;
              return mp_state != media_player::MediaPlayerState::MEDIA_PLAYER_STATE_ANNOUNCING ||
                     id(${voice_assistant_phase_global_id}) != ${voice_assist_replying_phase_id} ||
                     id(${timer_ringing_switch_id}).state;
          then:
            - lambda: |-
                id(aura_mouth_smooth) = 0.0f;
                id(aura_speaking_frame) = 0;
            - if:
                condition:
                  lambda: return id(aura_last_speaking_frame) != 0;
                then:
                  - lambda: id(aura_last_speaking_frame) = 0;
                  - lvgl.image.update:
                      id: aura_main_image
                      src: aura_idle_standby_img


  # ----------------------------------------------------
  # AURA - RETRY DOWNLOAD ASSET
  # ----------------------------------------------------
  - interval: 30s
    then:
      - if:
          condition:
            lambda: |-
              return id(${wifi_component_id}).is_connected() &&
                     !id(aura_assets_ready) &&
                     !id(aura_assets_download_started);
          then:
            - lambda: id(aura_assets_download_started) = true;
            - component.update: aura_idle_standby_img

  - interval: 24h
    then:
      - if:
          condition:
            wifi.connected:
          then:
            - if:
                condition:
                  lambda: return id(${fw_update_check_enabled_id});
                then:
                  - script.execute: ${script_check_firmware_version_id} 

  - interval: 5s
    then:
      - if:
          condition:
            lambda: |-
              return id(${va_modalita_continua_id}) &&
                     id(${voice_assistant_id}).is_running() &&
                     id(${voice_assistant_phase_global_id}) != ${voice_assist_thinking_phase_id} &&
                     id(${voice_assistant_phase_global_id}) != ${voice_assist_replying_phase_id} &&
                     id(${voice_assistant_phase_global_id}) != ${voice_assist_error_phase_id} &&
                     id(${va_ultimo_input_ms_id}) > 0 &&
                     (millis() - id(${va_ultimo_input_ms_id}) > 60000UL);
          then:
            - logger.log:
                level: INFO
                format: "==== Modalita continua: stop per inattivita"
            - voice_assistant.stop:

esphome:
  name: ${device_name}
  friendly_name: ${friendly}
  min_version: 2026.6.3
  compile_process_limit: 1
  project:
    name: Waveshare HackMyHome.AuraGC9A01A
    version: ${fw_version}

  on_boot:
    - priority: 600
      then:
        - lambda: |-
            id(aura_boot_finished) = false;
            id(aura_boot_started_ms) = millis();
            id(aura_ui_ready) = false;
            id(aura_download_step) = 0;
            id(aura_boot_progress_step) = 0;
            id(aura_boot_progress_error) = false;
            id(aura_download_status).clear();

    - priority: 375
      then:
        - sensor.template.publish:
            id: ${next_timer_sensor_id}
            state: -1
        - delay: 10min
        - if:
            condition:
              lambda: return id(${init_in_progress_id});
            then:
              - lambda: id(${init_in_progress_id}) = false;

    - priority: -50
      then:
        # Re-apply restored numeric settings to the live audio components.
        - lambda: |-
            if (!std::isnan(id(${mic_gain_number_id}).state)) {
              id(${mic_gain_saved_id}) = id(${mic_gain_number_id}).state;
              if (!id(${mic_mute_switch_id}).state) {
                id(${audio_adc_id}).set_mic_gain(id(${mic_gain_number_id}).state);
              }
            }
            if (!std::isnan(id(${va_gain_factor_number_id}).state)) {
              id(${va_microphone_id}).set_gain_factor(id(${va_gain_factor_number_id}).state);
            }
            if (!std::isnan(id(${va_noise_suppression_number_id}).state)) {
              id(${voice_assistant_id}).set_noise_suppression_level(id(${va_noise_suppression_number_id}).state);
            }

    # Avvia l'anello fisico con l'effetto sincronizzato dopo
    # l'inizializzazione dei componenti hardware.
    - priority: -110
      then:
        - light.turn_on:
            id: ${status_ring_id}
            brightness: 100%
            effect: "Aura Sync"

    - priority: -100
      then:
        - lambda: |-
            id(${alarm_time_text_id}).publish_state(id(${saved_alarm_time_id}));
        - lambda: |-
            auto call = id(${alarm_action_select_id}).make_call();
            call.set_option(id(${saved_alarm_action_id}));
            call.perform();
        - lambda: |-
            setenv("TZ", id(${saved_time_zone_id}).c_str(), 1);
            tzset();

        - delay: 500ms
        - lambda: |-
            id(${display_id}).set_invert_colors(true);
            ESP_LOGI(
              "display_fix",
              "Forzato INVERT_ON sul GC9A01A"
            );
  area: Casa
